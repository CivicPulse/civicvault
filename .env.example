# Copy to `.env` for local development. Real values are injected as environment
# variables in production. The `.env` file itself is gitignored.

# Toggle Django debug mode. Keep False (the default) in any shared environment.
DEBUG=True

# Comma-separated hostnames Django will serve. Empty is fine for local dev.
# Example for production: ALLOWED_HOSTS=civicvault.example.com,www.civicvault.example.com
ALLOWED_HOSTS=

# Cryptographic signing key. A safe dev default is baked into settings.py, but
# production MUST set a unique secret here.
# Generate one: uv run python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
# SECRET_KEY=

# Database connection. Omit to use local SQLite (the in-code fallback).
# Local dev uses the Postgres container from compose.yaml — bring it up with
#   docker compose up -d db
# It publishes on host port 5433 (5432 is often taken by a host Postgres):
DATABASE_URL=postgres://civicvault:civicvault@localhost:5433/civicvault

# Optional: override the compose Postgres credentials/port. Defaults match the
# DATABASE_URL above; change them together if you customize them.
# POSTGRES_USER=civicvault
# POSTGRES_PASSWORD=civicvault
# POSTGRES_DB=civicvault
# POSTGRES_PORT=5433

# Cloudflare R2 object storage (media: PDFs, audio, video). Leave R2_BUCKET
# empty for local dev to fall back to filesystem storage. R2 has zero egress.
# R2_BUCKET=civicvault-media
# R2_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# Public Cloudflare domain fronting the bucket; sets media read URLs to
# https://<domain>/<key>. Leave empty to use the private S3 endpoint.
# R2_CUSTOM_DOMAIN=data.example.org

# Remote ingest API token. Authenticates the local push tool (push_bcsd) to
# /api/v1. Unset → the API denies all requests. Generate a high-entropy value:
#   uv run python -c "import secrets; print(secrets.token_urlsafe(48))"
# INGEST_API_TOKEN=
# Optional: presigned upload URL lifetime in seconds (default 3600).
# INGEST_UPLOAD_URL_TTL=3600
